# Copy to .env and fill in. NEVER commit .env.

# GitHub personal access token (free).
# Generate at: https://github.com/settings/tokens?type=beta
# No scopes needed for public repos — uncheck everything.
# This token is used by the server to proxy GitHub requests, raising the
# shared rate limit from 60 req/hour (per visitor IP) to 5000 req/hour
# (pooled across all visitors).
GITHUB_TOKEN=

# Port to listen on. Default 3000.
PORT=3000

# Per-IP rate limit on /api/* (requests per hour). Prevents one visitor
# from draining the shared pool. Default 60.
RATE_LIMIT_PER_HOUR=60
